# ---------------------------------------------------------------
# Database
# Use postgresql+asyncpg:// scheme — required for async SQLAlchemy
# Railway provides this string in your PostgreSQL service dashboard
# ---------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname

# ---------------------------------------------------------------
# JWT Auth
# Generate SECRET_KEY with:
#   python -c "import secrets; print(secrets.token_hex(32))"
# Never reuse this value across environments
# ---------------------------------------------------------------
SECRET_KEY=<replace-with-64-char-hex-string>
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ---------------------------------------------------------------
# Twilio SMS (Step 10)
# Obtain from console.twilio.com after creating an account
# ---------------------------------------------------------------
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_FROM_NUMBER=+1xxxxxxxxxx

# ---------------------------------------------------------------
# Spotify Web API (artist preview embeds)
# Register an app at developer.spotify.com/dashboard
# Client Credentials flow only — no user OAuth required
# ---------------------------------------------------------------
SPOTIFY_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SPOTIFY_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ---------------------------------------------------------------
# Web Push (VAPID keypair)
# Generate once with:
#   python -m scripts.gen_vapid_keys
# VAPID_PUBLIC_KEY is also exposed to the frontend as
# NEXT_PUBLIC_VAPID_PUBLIC_KEY (different env file, same value)
# ---------------------------------------------------------------
VAPID_PUBLIC_KEY=<replace-with-base64url-public-key>
VAPID_PRIVATE_KEY=<replace-with-base64url-private-key>
VAPID_SUBJECT=mailto:trevor@usetotem.app

# ---------------------------------------------------------------
# CORS + invite link base URL
# Local dev: set to http://localhost:3000
# Production: set to https://usetotem.app
# ---------------------------------------------------------------
FRONTEND_URL=http://localhost:3000
